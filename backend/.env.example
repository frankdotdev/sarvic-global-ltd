# =============================================================
# SARVIC GLOBAL LTD — Backend Environment Variables
# Copy this file to .env and fill in your actual values
# =============================================================

# Server
NODE_ENV=development
PORT=4000

# Database (PostgreSQL — Supabase, Neon, Railway, or self-hosted VPS)
DATABASE_URL=postgresql://user:password@localhost:5432/sarvic_global

# JWT Auth
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=8h

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://sarvicglobal.com,https://www.sarvicglobal.com

# Admin notification recipient (where contact/quote forms are sent)
ADMIN_EMAIL=sarvicglobaltd@gmail.com

# =============================================================
# EMAIL — Resend (ACTIVE — get free API key at resend.com)
# =============================================================
RESEND_API_KEY=
FROM_EMAIL=notifications@sarvicglobal.com

# =============================================================
# SMS — Termii (OPTIONAL — wired but inactive until key is added)
# Starts working automatically once these are set, no code changes needed
# =============================================================
TERMII_API_KEY=
TERMII_SENDER_ID=Sarvic

# =============================================================
# WHATSAPP — Meta Cloud API (OPTIONAL — wired but inactive until keys are added)
# Starts working automatically once these are set, no code changes needed
# =============================================================
META_WA_TOKEN=
META_WA_PHONE_ID=

# =============================================================
# SUPABASE (if using Supabase for Auth/Storage instead of self-hosted)
# =============================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=shipment-documents
